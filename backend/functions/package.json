{
  "name": "functions",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "lint:fix": "eslint --ext .js,.ts . --fix",
    "build": "tsc",
    "build:incremental": "tsc --incremental",
    "build:watch": "tsc --watch",
    "build:watch:incremental": "tsc --watch --incremental",
    "serve": "firebase emulators:start --only auth,functions,tasks,firestore,pubsub,storage --project=local --import ../sim --export-on-exit=../sim",
    "serve:inspect": "firebase emulators:start --inspect-functions --only auth,functions,tasks,firestore,pubsub,storage --project=local --import ../sim --export-on-exit=../sim",
    "serve:test": "firebase emulators:start --only auth,functions,firestore,pubsub,storage --project=local",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run build && npm run serve",
    "deploy": "firebase deploy",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.1.0",
    "firebase-functions": "^6.3.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "eslint": "^8.15.0",
    "eslint-plugin-import": "^2.31.0",
    "typescript": "^5.7.3"
  }
}
