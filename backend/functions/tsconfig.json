{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "esModuleInterop": true,
    "incremental": false
  },
  "compileOnSave": true,
  "include": [
    "src",
    "test",
  ],
  "exclude": [
    "node_modules"
  ],
}
